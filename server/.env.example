# Portul pe care rulează serverul
PORT=4000

# Chei VAPID pentru Web Push. Generează-le o singură dată cu: npm run genkeys
# apoi copiază valorile aici.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu@example.com

# Secret pentru endpoint-ul apelat de cron-job.org (/api/run-reminders).
# Pune orice șir lung și aleatoriu. Îl folosești și în URL-ul cron-ului:
#   https://.../api/run-reminders?key=ACEST_SECRET
CRON_SECRET=

# Connection string de la Neon (https://neon.tech) — baza de date permanentă.
# Ex: postgresql://user:parola@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
